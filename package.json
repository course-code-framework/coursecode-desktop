{
  "name": "coursecode-desktop",
  "version": "0.10.0-beta.2",
  "description": "A native GUI for CourseCode — create, preview, and deploy interactive courses",
  "main": "./out/main/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/course-code-framework/coursecode-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/course-code-framework/coursecode-desktop/issues"
  },
  "homepage": "https://coursecodedesktop.com",
  "packageManager": "npm@11.10.0",
  "license": "MIT",
  "author": "Seth Vincent",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "dev": "electron-vite dev",
    "dev:local": "COURSECODE_LOCAL=1 electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "package": "npm run icons && electron-vite build && electron-builder --config electron-builder.yml",
    "package:mac": "npm run icons && electron-vite build && electron-builder --mac --config electron-builder.yml",
    "package:win": "npm run icons && electron-vite build && electron-builder --win --config electron-builder.yml",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "svelte": "^5.55.5",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@tiptap/core": "^3.22.4",
    "@tiptap/markdown": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "coursecode": "^0.1.43",
    "electron-updater": "^6.3.9",
    "isomorphic-git": "^1.37.6",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
    "npm": "^11.10.0",
    "openai": "^6.21.0",
    "win-ca": "^3.5.1"
  }
}
